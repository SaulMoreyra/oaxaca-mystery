; Engine configuration file.
; Oaxaca Mystery — vertical slice (Godot 4)
; Hand-written for the greybox prototype. Open with Godot 4.2+ and it will
; finish importing textures and assign UIDs automatically.

config_version=5

[application]

config/name="Oaxaca Mystery"
config/description="Vertical slice — master potter in Atzompa (2D side-scroller action)."
run/main_scene="res://scenes/Level01_Atzompa.tscn"
config/features=PackedStringArray("4.2", "Mobile")
config/icon="res://icon.svg"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"
window/handheld/orientation="landscape"

